# ===== Root Environment Template =====
# Copy this file to .env at repository root.
# Some values are consumed by apps/api and some by apps/web.

# --- Core Runtime ---
NODE_ENV=development

# --- API Server ---
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/broady
DATABASE_DIRECT_URL=postgresql://postgres:postgres@localhost:5432/broady
JWT_SECRET=replace_with_long_random_secret
WEB_APP_URL=http://localhost:3000

# --- OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Web Runtime ---
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_USE_MOCK_FALLBACK=false

# --- Media / External Integrations ---
CLOUDINARY_URL=
AWS_S3_BUCKET=
CLOUDFLARE_CDN_URL=
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=notifications@broady.pk
WHATSAPP_WEBHOOK_URL=

# --- Notifications and Queue ---
REDIS_URL=redis://127.0.0.1:6379
NOTIFICATION_QUEUE_ADAPTER=redis
NOTIFICATION_REDIS_QUEUE_NAME=broady-notifications
NOTIFICATION_REDIS_PREFIX=broady
NOTIFICATION_WORKER_POLL_MS=250
NOTIFICATION_WORKER_CONCURRENCY=4
NOTIFICATION_WORKER_LOCK_TIMEOUT_MS=30000
NOTIFICATION_WORKER_MAX_ATTEMPTS=3
NOTIFICATION_WORKER_SHUTDOWN_WAIT_MS=5000
NOTIFICATION_WORKER_EMBEDDED=true
NOTIFICATION_WORKER_HEALTH_PORT=0

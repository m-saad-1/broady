# ===== Root Environment Template =====
# Copy this file to .env at repository root.
# Some values are consumed by apps/api and some by apps/web.

# --- Core Runtime ---
NODE_ENV=development

# --- API Server ---
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/broady
DATABASE_DIRECT_URL=postgresql://postgres:postgres@localhost:5432/broady
JWT_SECRET=replace_with_long_random_secret
WEB_APP_URL=http://localhost:3000

# --- OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Web Runtime ---
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_USE_MOCK_FALLBACK=false
NEXT_PUBLIC_FIREBASE_API_KEY=replace_with_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=broady-1.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=broady-1
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=broady-1.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=190709096272
NEXT_PUBLIC_FIREBASE_APP_ID=1:190709096272:web:8d7d2b10d38f27ee0f1655
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-WS9W2XZJPV
NEXT_PUBLIC_FIREBASE_VAPID_KEY=BPpTKerM6IDfpLCLWrcescfMj8_GPY6RfnvR_HgWarWIzxi6fMH0bmyH36ikc_sKo681zDJJISGQeLetdZ1N_No

# --- Media / External Integrations ---
CLOUDINARY_URL=
AWS_S3_BUCKET=
CLOUDFLARE_CDN_URL=
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=notifications@broady.pk
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
WHATSAPP_WEBHOOK_URL=
PAYMENT_WEBHOOK_SECRET=replace_with_gateway_webhook_secret
FIREBASE_PROJECT_ID=broady-1
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Alternative to FIREBASE_CLIENT_EMAIL/FIREBASE_PRIVATE_KEY for FCM HTTP v1.
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Notifications and Queue ---
REDIS_URL=redis://127.0.0.1:6379
NOTIFICATION_QUEUE_ADAPTER=redis
NOTIFICATION_REDIS_QUEUE_NAME=broady-notifications
NOTIFICATION_REDIS_PREFIX=broady
NOTIFICATION_WORKER_POLL_MS=250
NOTIFICATION_WORKER_CONCURRENCY=4
NOTIFICATION_WORKER_LOCK_TIMEOUT_MS=30000
NOTIFICATION_WORKER_MAX_ATTEMPTS=3
NOTIFICATION_WORKER_SHUTDOWN_WAIT_MS=5000
NOTIFICATION_WORKER_EMBEDDED=true
NOTIFICATION_WORKER_HEALTH_PORT=0

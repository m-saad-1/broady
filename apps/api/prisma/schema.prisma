generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

enum Role {
  USER
  ADMIN
  BRAND
  BRAND_ADMIN
  BRAND_STAFF
  SUPER_ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELED
}

enum PaymentStatus {
  PENDING
  HELD
  BRAND_COLLECTS_COD
  COMPLETED
}

enum PaymentMethod {
  COD
  JAZZCASH
  EASYPAISA
}

enum UserPaymentType {
  CARD
  JAZZCASH
  EASYPAISA
  BANK
}

enum OrderStatusUpdatedBy {
  SYSTEM
  BRAND
  ADMIN
}

enum NotificationType {
  ORDER_PLACED
  ORDER_STATUS_UPDATED
  BRAND_ORDER_ASSIGNED
}

enum NotificationChannel {
  DASHBOARD
  EMAIL
  WHATSAPP
}

enum NotificationDeliveryStatus {
  SENT
  QUEUED
  FAILED
}

enum ProductApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

model User {
  id          String         @id @default(cuid())
  email       String         @unique
  fullName    String
  password    String?
  googleId    String?        @unique
  authProvider AuthProvider  @default(LOCAL)
  role        Role           @default(USER)
  brandId     String?        @unique
  brand       Brand?         @relation("BrandOwnership", fields: [brandId], references: [id], onDelete: SetNull)
  brandInviteTokenHash String?
  brandInviteTokenExpiresAt DateTime?
  brandInviteAcceptedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  sessions    Session[]
  cart        Cart?
  orders      Order[]
  wishlistItems WishlistItem[]
  paymentMethods UserPaymentMethod[]
  notificationPreference NotificationPreference?
  brandMemberships BrandMember[]
  notifications Notification[]
}

model UserPaymentMethod {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         UserPaymentType
  label        String
  last4        String
  expiresMonth Int?
  expiresYear  Int?
  isDefault    Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([userId, createdAt])
}

model NotificationPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderUpdates      Boolean  @default(true)
  promoEmails       Boolean  @default(false)
  securityAlerts    Boolean  @default(true)
  wishlistAlerts    Boolean  @default(true)
  updatedAt         DateTime @updatedAt
}

model Cart {
  id         String     @id @default(cuid())
  userId     String     @unique
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      CartItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model CartItem {
  id         String    @id @default(cuid())
  cartId     String
  cart       Cart      @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId  String
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity   Int       @default(1)
  selectedColor String?
  selectedSize  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([cartId, productId, selectedColor, selectedSize])
  @@index([productId])
}

model Session {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenId     String    @unique
  userAgent   String?
  ipAddress   String?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, expiresAt])
}

model Brand {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  logoUrl     String?
  description String?
  verified    Boolean   @default(true)
  commissionRate Float  @default(12)
  apiEnabled   Boolean  @default(false)
  contactEmail String?
  whatsappNumber String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
  members     BrandMember[]
  orderItems  OrderItem[]
  notifications Notification[]
  owner       User?         @relation("BrandOwnership")
}

model BrandMember {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandId          String
  brand            Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  canManageProducts Boolean @default(true)
  createdAt        DateTime @default(now())

  @@unique([userId, brandId])
  @@index([brandId])
}

model Product {
  id          String    @id @default(cuid())
  brandId     String
  brand       Brand     @relation(fields: [brandId], references: [id])
  approvalStatus ProductApprovalStatus @default(APPROVED)
  approvalReviewedAt DateTime?
  approvalReviewedById String?
  name        String
  slug        String    @unique
  description String
  pricePkr    Int
  topCategory String
  subCategory String
  sizes       String[]
  imageUrl    String
  stock       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cartItems   CartItem[]
  orderItems  OrderItem[]
  wishlistItems WishlistItem[]

  @@index([brandId, topCategory, subCategory])
  @@index([topCategory, subCategory])
  @@index([pricePkr])
}

model WishlistItem {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, productId])
}

model Order {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(PENDING)
  totalPkr      Int
  deliveryAddress String
  trackingId    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         OrderItem[]
  statusLogs    OrderStatusLog[]
  notifications Notification[]

  @@index([userId, status])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  brandId    String
  brand      Brand    @relation(fields: [brandId], references: [id])
  quantity   Int
  unitPricePkr Int

  @@index([brandId, orderId])
}

model OrderStatusLog {
  id          String               @id @default(cuid())
  orderId     String
  order       Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      OrderStatus
  updatedBy   OrderStatusUpdatedBy
  updatedById String?
  note        String?
  createdAt   DateTime             @default(now())

  @@index([orderId, createdAt])
}

model Notification {
  id        String                @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  userId    String?
  user      User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandId   String?
  brand     Brand?                @relation(fields: [brandId], references: [id], onDelete: Cascade)
  orderId   String?
  order     Order?                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  readAt    DateTime?
  createdAt DateTime              @default(now())
  channels  NotificationChannelLog[]

  @@index([userId, createdAt])
  @@index([brandId, createdAt])
}

model NotificationChannelLog {
  id             String                     @id @default(cuid())
  notificationId String
  notification   Notification               @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel        NotificationChannel
  status         NotificationDeliveryStatus
  recipient      String
  error          String?
  createdAt      DateTime                   @default(now())

  @@index([notificationId])
}
